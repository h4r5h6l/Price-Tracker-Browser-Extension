{
  "manifest_version": 3,
  "name": "Amazon Price Compare",
  "version": "0.1.0",
  "description": "Adds a slide-in panel to Amazon product pages showing prices from other websites.",
  "content_scripts": [
    {
      "matches": [
  "https://www.amazon.de/*",
  "https://www.amazon.com/*",
  "https://www.amazon.in/*",
  "https://www.temu.com/*",
  "https://www.mediamarkt.de/*"
],
      "css": ["price-panel.css"],
      "js": ["price-panel.js"]
    }
  ]
}
